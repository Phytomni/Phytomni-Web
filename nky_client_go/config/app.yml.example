# nky_client_go runtime configuration template.
#
# Copy this file to `app.yml` in the same directory, then fill in real
# values; do NOT commit `app.yml` — the matching .gitignore rule keeps
# it out of git so live credentials never enter version control.

# ---------------------------------------------------------------------
# Application identity + log verbosity
# ---------------------------------------------------------------------
# `app.trusted_proxies` feeds gin.Engine.SetTrustedProxies (server/http.go)
# so X-Forwarded-* headers from these CIDRs are honored. Default in code
# is ["192.0.0.0/8", "172.16.0.0/12"]; override here if your ingress sits
# in a different subnet (Kubernetes overlay, public load balancer, etc.).
app:
  trusted_proxies:
    - "192.0.0.0/8"
    - "172.16.0.0/12"
debug: true

# ---------------------------------------------------------------------
# JWT signing secret — MUST equal SECRET_KEY_CLIENT in the Python
# sibling's .env, otherwise tokens issued by one side fail verification
# on the other. Use a long random string (e.g. `openssl rand -hex 32`).
# ---------------------------------------------------------------------
jwt:
  secret_key: "your-random-jwt-secret"

# ---------------------------------------------------------------------
# MySQL connection. The Logger hook (db/logger.go) writes every SQL
# into s_sql_operation_logs, so the DSN user needs INSERT on that table
# plus the SUser-family tables. Format:
#   <user>:<pass>@tcp(<host>:<port>)/<db>?<gorm-flags>
# ---------------------------------------------------------------------
db:
  nky_client_go:
    dialect: mysql
    dsn: "root:your-mysql-password@tcp(localhost:3306)/nongke?charset=utf8mb4&parseTime=True&loc=Local"

# ---------------------------------------------------------------------
# Redis cache (cache/client.go); currently initialized but main.go
# leaves the client commented out, so this section only matters once
# the cache layer is wired in.
# ---------------------------------------------------------------------
redis:
  clients:
    web:
      addrs:
        - "your-redis-host:6379"
      db: 0
      password:
      type: single-node
  default: default

# ---------------------------------------------------------------------
# Structured logging sinks
# ---------------------------------------------------------------------
log:
  outputs:
    - stdout
    - ./logs/api.log

# ---------------------------------------------------------------------
# Feature switches — http server + cron scheduler
#
# `http.switch` is the master kill-switch for the gin engine wiring.
# `http.gzip` toggles the gzip response middleware (off by default —
# turning it on burns CPU on small responses but trims body size for
# the large analyst-agent payloads). `http.maintenance` flips every
# non-health route to 503 so ops can drain traffic before a deploy.
# ---------------------------------------------------------------------
http:
  switch: true
  gzip: false
  maintenance: false
cron:
  switch: true

# ---------------------------------------------------------------------
# KooSearch (RAG) endpoints used by the KnowledgeAgent integration
# ---------------------------------------------------------------------
koosearch:
  url:
    question_url: "http://your-koosearch-host:8000/v1/koosearch/experience/chat"
    search_url: "http://your-koosearch-host:8000/v1/koosearch/experience/search"
    # Prefix used by ApiKooSearchDownloadFiles to mint per-file download
    # URLs (the handler appends the query "file" verbatim). Production
    # historically inlined the same host as a scheme-less literal — keep
    # the protocol explicit here so the frontend never builds //host URLs.
    files_url: "http://your-koosearch-host:8000/v1/koosearch/repos/files/"

# ---------------------------------------------------------------------
# Gene example file root — ApiGeneDetails reads files from here.
# Point at the directory that holds the per-gene .out artifacts the
# Python MCP server emits.
# ---------------------------------------------------------------------
gene_file_path: "/var/lib/phytomni/gene_examples"

# ---------------------------------------------------------------------
# Default chat quota for newly-created guest accounts. ApiUserRegister
# reads this for the `guest` role; logged-in vip/user roles are
# unbounded.
# ---------------------------------------------------------------------
guest_default_chat_limit: 5

# ---------------------------------------------------------------------
# Dify chat-messages API — service/api_service/dialogue_demo.go calls
# RunDialogue which POSTs to this URL with Bearer api_key. Both keys
# are required; the runtime errors out when either is empty.
# ---------------------------------------------------------------------
dify:
  chat_messages_url: "http://your-dify-host/v1/chat-messages"
  api_key: "your-dify-app-key"

# ---------------------------------------------------------------------
# Huawei Cloud IAM + EIHealth — service/api_service/agent_task.go
# uses these for the analyst-agent polling cron and the on-demand
# task-log fetch. The IAM block authenticates against a Huawei Cloud
# project; the EIHealth block points at the bioinformatics compute
# tenant where analyst tasks actually run.
#
# Rotate `iam.password` whenever the leaked sample value is suspected
# of being known to a third party (it is no longer the active one in
# this repository). Production typically deploys with region/auth_url
# wired together so both keys swap atomically on a region migration.
# ---------------------------------------------------------------------
huawei:
  iam:
    user_name: "your-huawei-iam-user"
    password: "your-huawei-iam-password"
    domain_name: "your-huawei-iam-domain"
    project_name: "cn-east-3"
    auth_url: "https://iam.cn-east-3.myhuaweicloud.com/v3/auth/tokens"
  eihealth:
    base_url: "https://eihealth.cn-east-3.myhuaweicloud.com/v1"
    account_id: "your-huawei-account-id"
    project_uuid: "your-eihealth-project-uuid"
  # OBS download credentials — service/api_service/gene_test_list.go reads
  # these to mint signed URLs for AnalystAgent result downloads. Rotate by
  # editing config/app.yml; never inline ak/sk back into source files.
  obs:
    ak: "your-huawei-obs-access-key"
    sk: "your-huawei-obs-secret-key"
    endpoint: "https://obs.cn-east-3.myhuaweicloud.com"
  # Huawei API Gateway — service/api_service/token.go signs and POSTs to
  # this URL to mint the cached HW token in Redis (RedisHWTokenKey). The
  # `<deployment-id>.apigw.<region>.myhuaweicloud.com` host changes per
  # ops stage (staging vs prod use different deployments), so keep the
  # full URL — query string and all — in config rather than reassembling
  # from parts.
  apigw:
    app1_url: "https://your-deployment-id.apigw.your-region.myhuaweicloud.com/app1?a=1&b=2"

# ---------------------------------------------------------------------
# Outbound notification email — common/email/email_send.go.
# `web_base_url` / `api_base_url` are stitched into the link bodies of
# the notification email (chat page + OBS file download). `from_*` are
# the QQ-SMTP credentials used to actually send. The auth code is a
# real production credential previously inlined as a literal; rotating
# requires updating config/app.yml + restarting the Go service.
# ---------------------------------------------------------------------
email:
  web_base_url: "http://your-web-host"
  api_base_url: "http://your-api-host:8082"
  smtp_server: "smtp.qq.com"
  smtp_port: 587
  from_display: "nky_email <your-sender@qq.com>"
  from_address: "your-sender@qq.com"
  from_auth_code: "your-qq-smtp-auth-code"
