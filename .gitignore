# ==================== 通用忽略规则 ====================

# 操作系统生成的文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDE和编辑器文件
.idea/
.vscode/
*.swp
*.swo
*~

# 日志文件
*.log

# 环境变量文件（包含敏感信息）

.env.local
.env.production
.env.development

# 临时文件和缓存
tmp/
temp/



# ==================== Go语言特定规则 ====================

# Go二进制文件
*.exe
*.out
*.app

# Go编译文件
bin/
pkg/

# Go测试文件
*.test
*.prof

# Go模块缓存
go/pkg/mod/

# ==================== Python特定规则 ====================

# Python虚拟环境
.venv/
venv/
env/

# Python字节码缓存
__pycache__/
*.py[cod]
*$py.class

# Python 测试/类型检查缓存(repo-wide tooling 的本地产物)
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter笔记本缓存
.ipynb_checkpoints/

# Python包构建产物
build/
dist/
*.egg-info/

# Python特定文件
.python-version
uv.lock

# 数据库文件（SQLite）
*.db
*.sqlite
*.sqlite3
server_tasks.db



# Python 端 dotenv（含真凭据，永远不进 git；模板见 nky_client_python/.env.example）
nky_client_python/.env
# Go 配置文件（含真凭据；模板见 nky_client_go/config/app.yml.example）
nky_client_go/config/app.yml
# 前端 Vite mode-specific env（模板见 chat-ai/.env.dev.example 等）
chat-ai/.env
chat-ai/.env.dev
chat-ai/.env.prod
chat-ai/.env.staging

# Claude Code
.claude/
CLAUDE.md

# Local agent context
.codex
AGENTS.md

.cursor
.codegraph