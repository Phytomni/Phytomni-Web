# Phytomni MCP client — environment template
#
# Copy this file to `.env` in the same directory and fill in real values.
# Do NOT commit `.env` to git — it is intentionally listed in .gitignore.
# Every key below is read by nky_client.py / tool_format_processing.py
# (see `git grep "os.getenv"` for the load sites).

# ---------------------------------------------------------------------------
# JWT signing secret — MUST match `jwt.secret_key` in
# nky_client_go/config/app.yml so tokens issued by the Go API validate here.
# ---------------------------------------------------------------------------
SECRET_KEY_CLIENT = "your-random-jwt-secret"

# ---------------------------------------------------------------------------
# LLM endpoint — defaults to DeepSeek; swap base_url + model for OpenAI etc.
# ---------------------------------------------------------------------------
BASE_URL_CLIENT = "https://api.deepseek.com/v1"
MODEL_CLIENT = "deepseek-reasoner"
OPENAI_API_KEY_CLIENT = "your-deepseek-or-openai-key"

# ---------------------------------------------------------------------------
# Database DSN — pick the OS-appropriate variant; nky_client.py reads
# DATABASE_URL_CLIENT_WIN on Windows hosts and ..._LINUX elsewhere.
# Format: mysql+pymysql://<user>:<pass>@<host>[:<port>]/<db>
# ---------------------------------------------------------------------------
DATABASE_URL_CLIENT_WIN = "mysql+pymysql://root:your-mysql-password@localhost/nongke"
DATABASE_URL_CLIENT_LINUX = "mysql+pymysql://root:your-mysql-password@db.host.local/nongke"
