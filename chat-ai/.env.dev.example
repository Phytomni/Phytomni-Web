# chat-ai dev-mode environment template
#
# Copy to `.env.dev` in this directory and fill in real values; do NOT
# commit `.env.dev` — the .gitignore rule keeps it out of git so the
# UI's dev-time endpoints stay separate from any tracked sample.
#
# Vite loads this file when `vite --mode dev` runs (see package.json
# `dev` script), so VITE_* keys here override `.env` defaults.

# Whether Babel transpiles modules at dev-server time (vite-plugin-babel)
VITE_BABEL_TRANSPILE_MODULES = true

# Browser tab title shown by the dev server
VITE_APP_TITLE = "Phytomni Web (dev)"

# Vite mode marker — leave as 'development' unless you know you need 'staging'
VITE_APP_ENV = 'development'

# Static-asset URL prefix; usually empty for same-origin dev
VITE_APP_BASE_URL = ''

# API gateway prefix — must match the dev-server proxy in vite.config.ts
# Defaults to '/auth' so the Go API at :8082 is reachable through the proxy.
VITE_BASE_API = '/auth'

# File-upload gateway prefix (Huawei OBS dispatch route)
VITE_FILE_BASE = '/ftnet-gateway'

# Optional in-app navigation link surfaced in the header (leave blank to hide)
VUE_APP_NAV = ''
